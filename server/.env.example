# Server
PORT=3001
NODE_ENV=development
DB_SYNC_ON_START=false

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:your_password_here@127.0.0.1:5432/youtoobe
DB_SSL=false

# Firebase Admin SDK
FIREBASE_PROJECT_ID=birzha-kanaliv
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@birzha-kanaliv.iam.gserviceaccount.com
JWT_SECRET=

# Google OAuth (for YouTube connect flow)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Must match Google Cloud Console Authorized redirect URI exactly
GOOGLE_REDIRECT_URI=https://api.birzha-kanaliv.biz.ua/api/youtube/callback

# Leonardo AI blog image generation
LEONARDO_API_KEY=
LEONARDO_MODEL_ID=aa77f04e-3eec-4034-9c07-d0f619684628
LEONARDO_STYLE_UUID=
LEONARDO_API_URL=https://cloud.leonardo.ai/api/rest/v1

# Client URLs for CORS (comma-separated)
# Local development:
FRONTEND_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:5174
# Production:
# CLIENT_URLS=https://birzha-kanaliv.biz.ua,https://admin.birzha-kanaliv.biz.ua
# Optional legacy single URL:
# CLIENT_URL=https://birzha-kanaliv.biz.ua

# Telegram bot notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_LINK_SECRET=change_me_telegram_secret

# Security
OAUTH_STATE_SECRET=change_me_oauth_state_secret
# 32-char string or 64-char hex key for token encryption
APP_ENCRYPTION_KEY=

# Optional distributed rate limiting
REDIS_URL=
